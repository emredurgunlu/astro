---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, LANGUAGES_KEYS } from "../../i18n/utils";

import heroImage from "../../assets/images/hero.webp";
import logoImage from "../../assets/images/logo.webp";
import ataturkImage from "../../assets/images/ataturk.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  return LANGUAGES_KEYS.map((lang) => ({ params: { lang } }));
}
---
<Layout title={t.site.title} description={t.site.description} lang={lang}>
  <section class="hero bg-base-200 rounded-box">
    <div class="hero-content text-center">
      <div class="w-full">
        <div class="relative rounded-3xl overflow-hidden shadow-lg">
          <img src={heroImage.src} alt="Adalet Görseli" class="w-full h-[220px] md:h-[320px] lg:h-[420px] object-cover object-center" loading="lazy" />
          <div class="absolute inset-x-0 bottom-0 p-6 md:p-8 flex flex-col items-center">
            <img src={logoImage.src} alt={t.site.title} class="w-40 md:w-56 mb-3" loading="lazy" />
            <blockquote class="text-lg md:text-xl font-semibold text-center text-base-content italic mb-2">
              "Bağımsızlık, istikbal, hürriyet; her şey adaletle mevcuttur."
            </blockquote>
            <img src={ataturkImage.src} alt="Atatürk İmza" class="w-24" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto max-w-6xl px-4 py-8">
    <h2 class="text-2xl font-bold mb-4">{t.nav.practiceAreas}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { slug: "vehicle-value-loss", label: t.nav.practiceAreasItems.vehicleValueLoss },
        { slug: "family-law", label: t.nav.practiceAreasItems.familyLaw },
        { slug: "cybercrimes", label: t.nav.practiceAreasItems.cybercrimes },
        { slug: "real-estate-zoning", label: t.nav.practiceAreasItems.realEstateZoningLaw },
        { slug: "inheritance-law", label: t.nav.practiceAreasItems.inheritanceLaw },
        { slug: "foreigners-citizenship", label: t.nav.practiceAreasItems.foreignersCitizenshipLaw },
        { slug: "criminal-law", label: t.nav.practiceAreasItems.criminalLaw },
        { slug: "labor-law", label: t.nav.practiceAreasItems.laborLaw },
        { slug: "enforcement-bankruptcy", label: t.nav.practiceAreasItems.enforcementBankruptcyLaw }
      ].map((item) => (
        <a href={`/${lang}/blog/${item.slug}`} class="card bg-base-100 shadow-sm hover:shadow-md transition hover:-translate-y-0.5 border rounded-box">
          <div class="card-body">
            <h3 class="card-title text-lg md:text-xl">{item.label}</h3>
            <div class="card-actions justify-end">
              <span class="btn btn-sm btn-primary">Detay</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

</Layout>
